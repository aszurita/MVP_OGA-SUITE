# ─────────────────────────────────────────────────────────────────────────────
# OGA-SUITE — Variables de Entorno
# Copia este archivo a .env y rellena con los valores reales
# NUNCA commitear el .env real al repositorio
# ─────────────────────────────────────────────────────────────────────────────

# ── API Backend ───────────────────────────────────────────────────────────────
# URL de la API en desarrollo directo (sin Docker)
VITE_API_URL=http://gobinfoana01-2:8510
# En Docker esto se ignora — Nginx hace el proxy internamente

# ── Base de Datos SQL Server ──────────────────────────────────────────────────
DB_HOST=gobinfoana01-2
DB_PORT=1433
DB_NAME=PROCESOS_BI
DB_USER=tu_usuario_aqui
DB_PASS=tu_contraseña_aqui

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=ogaredis2024
# En Azure esto viene de Azure Cache for Redis connection string

# ── Azure (cuando se suba a producción) ───────────────────────────────────────
# AZURE_ACR_NAME=ogasuiteacr
# AZURE_RESOURCE_GROUP=rg-oga-suite
# AZURE_CONTAINER_APP=oga-suite-app
